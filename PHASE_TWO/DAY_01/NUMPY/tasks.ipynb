    "Task 1 — Basic creation and inspection\n",
    "Create a 2D array of shape (4, 5) filled with random integers between 1 and 50. Print its shape, dtype, and the total number of elements."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "bdaaad00",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[[28 39 49 35 47]\n",
      " [33 10  2 49 14]\n",
      " [20 41  3 34 20]\n",
      " [41  5 49 36 31]]\n",
      "\n",
      "(4, 5)\n",
      "\n",
      "int32\n",
      "\n",
      "20\n",
      "\n"
     ]
    }
   ],
   "source": [
    "import numpy as np\n",
    "\n",
    "a = np.random.randint(1, 50, size = (4,5))\n",
    "\n",
    "print(a)\n",
    "print()\n",
    "print(a.shape)\n",
    "print()\n",
    "print(a.dtype)\n",
    "print()\n",
    "print(a.size)\n",
    "print()"
   ]
