      "['Pass' 'Pass' 'Fail' 'Pass' 'Pass' 'Fail' 'Pass' 'Pass' 'Fail' 'Pass']\n",
      "\n"
     ]
    }
   ],
   "source": [
    "import numpy as np\n",
    "\n",
    "scores = np.array([72, 85, 60, 91, 78, 55, 88, 74, 67, 95])\n",
    "\n",
    "print(np.mean(scores))\n",
    "print()\n",
    "\n",
    "print(np.median(scores))\n",
    "print()\n",
    "\n",
    "print(np.max(scores))\n",
    "print()\n",
    "\n",
    "print(np.min(scores))\n",
    "print()\n",
    "\n",
    "print(np.argmax(scores))\n",
    "print()\n",
    "\n",
    "print(np.argmin(scores))\n",
    "print()\n",
    "\n",
    "result = np.where(scores >= 70, \"Pass\", \"Fail\")\n",
    "print(result)\n",
    "print()"
   ]
