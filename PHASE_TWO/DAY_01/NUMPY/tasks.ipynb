   "source": [
    "import numpy as np\n",
    "\n",
    "a = np.random.randint(1, 100, size = 100)\n",
    "print(a)\n",
    "print()\n",
    "\n",
    "mask = a > 60\n",
    "\n",
    "print(mask)\n",
    "print()\n",
    "print(mask.size)\n",
    "print()\n",
    "\n",
    "even = a[(a % 2 == 0) & (a < 50)]\n",
