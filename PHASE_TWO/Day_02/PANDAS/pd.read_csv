
# Other formats
df = pd.read_excel("data.xlsx")
df = pd.read_json("data.json")

# Useful parameters
df = pd.read_csv("data.csv", nrows=100)          # only load first 100 rows
df = pd.read_csv("data.csv", usecols=["name", "age"])  # only specific columns
df = pd.read_csv("data.csv", index_col="id")     # use a column as the index